{
  "name": "artisan-jewelry-mvp",
  "version": "1.0.0",
  "description": "MVP web system for selling artisan jewelry with custom design constructor.",
  "main": "server/index.js",
  "scripts": {
    "dev": "nodemon server/index.js",
    "dev:client": "vite --config client/vite.config.js",
    "build:client": "vite build --config client/vite.config.js",
    "start": "node server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "assets:generate-free": "node scripts/generate-free-mvp-images.js",
    "assets:rasterize": "node scripts/rasterize-assets.js",
    "db:migrate": "knex --knexfile knexfile.cjs migrate:latest",
    "db:rollback": "knex --knexfile knexfile.cjs migrate:rollback",
    "db:seed": "knex --knexfile knexfile.cjs seed:run",
    "db:reset": "knex --knexfile knexfile.cjs migrate:rollback --all && knex --knexfile knexfile.cjs migrate:latest && knex --knexfile knexfile.cjs seed:run"
  },
  "keywords": [
    "express",
    "sqlite",
    "docker",
    "knex",
    "jewelry",
    "mvp"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "google-auth-library": "^10.6.2",
    "image-size": "^2.0.2",
    "knex": "^3.1.0",
    "lucide-react": "^0.468.0",
    "nodemailer": "^8.0.7",
    "pptxgenjs": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.2",
    "sqlite3": "^5.1.7",
    "vite": "^5.4.21"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0",
    "vitest": "^2.1.4"
  }
}
